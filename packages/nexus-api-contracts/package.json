{
  "name": "@packages/nexus-api-contracts",
  "exports": {
    ".": "./dist/typedrest.contract.js"
  },
  "imports": {
    "#*": "./dist/*"
  },
  "scripts": {
    "gen-types:supabase": "supabase gen types typescript --project-id xrsmassoekhstkeuwozc > src/types/supabase.types.ts",
    "gen-types:zod": "supazod -i src/types/supabase.types.ts -o src/types/supabase.schema.ts",
    "gen-types": "pnpm run gen-types:supabase && pnpm run gen-types:zod",
    "dev": "typed-rest dev",
    "build": "typed-rest build",
    "gen-types:rebuild": "pnpm run gen-types && pnpm run build"
  },
  "dependencies": {
    "@configs/typescript-config": "workspace:*",
    "@packages/typed-rest": "workspace:*",
    "concurrently": "9.2.1",
    "express": "5.2.1",
    "supazod": "^4.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.0.3",
    "chokidar": "^5.0.0",
    "supabase": "2.76.12",
    "ts-node": "10.9.2",
    "tsc-alias": "1.8.16",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
