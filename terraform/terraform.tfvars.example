# =============================================================================
# Terraform Variables Example
# =============================================================================
# Copy this file to terraform.<env>.tfvars and fill in real values.
# NOTE: Do not commit terraform.tfvars if it contains sensitive data.
#
# Cloudflare API token is passed via env var (not in tfvars):
#   export TF_VAR_cloudflare_api_token="your-cloudflare-api-token"
# =============================================================================

# Required
# project_id = "gdg-pup-platform-dev"

# Optional
# region      = "asia-southeast1"
# environment = "dev"
# firestore_database_name  = "(default)"
# create_firestore_database = false

# --- Cloudflare DNS ---
# cloudflare_zone_id = "your-cloudflare-zone-id"
#
# domain_mappings = {
#   "nexus-web"    = { subdomain = "dev" }
#   "nexus-api"    = { subdomain = "api.dev" }
#   "identity-api" = { subdomain = "identity.dev" }
# }

