{
  "name": "gdg-pup-platform",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:nexus": "turbo dev --filter=nexus-api... --filter=identity-api... --filter=nexus-web...",
    "dev:nexusapi": "turbo dev --filter=nexus-api...",
    "dev:backend": "turbo dev --filter=identity-api... --filter=nexus-api...",
    "dev:storybook": "turbo dev --filter=storybook...",
    "build": "turbo run build --filter=!storybook",
    "build:nexus": "turbo build  --filter=nexus-api... --filter=identity-api... --filter=nexus-web...",
    "start": "turbo run start",
    "clean": "node scripts/clean/detect-shell.ts",
    "reinstall": "pnpm clean && pnpm install",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "gen-types": "turbo run gen-types",
    "gen-types:rebuild": "pnpm gen-types && pnpm build",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "prettier": "3.8.1",
    "syncpack": "14.2.0",
    "turbo": "2.8.16",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "clsx": "^2.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "rimraf": "^6.1.3",
    "tailwind-merge": "^3.4.0",
    "tsx": "^4.21.0"
  }
}
